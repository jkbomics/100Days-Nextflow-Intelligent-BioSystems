params {

    star_index = "./genome/star_index"
    annotation = "./genome/annotation.gtf"

}

process {

    executor = 'local'

    withLabel: qc {
        cpus = 2
        memory = '2 GB'
    }

    withLabel: trimming {
        cpus = 2
        memory = '4 GB'
    }

    withLabel: alignment {
        cpus = 8
        memory = '16 GB'
    }

    withLabel: quantification {
        cpus = 4
        memory = '8 GB'
    }

}

timeline {
    enabled = true
    file = "timeline.html"
}

report {
    enabled = true
    file = "execution_report.html"
}

dag {
    enabled = true
    file = "dag.png"
}